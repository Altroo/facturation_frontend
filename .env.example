# Urls prefix
DEBUG_MODE=false
NEXT_PUBLIC_HTTP_PROTOCOLE=https
HTTP=https://
WS=wss://
# CORS - Allowed origins for API requests (comma-separated)
ALLOWED_ORIGINS=https://facturation-api.elbouazzatiholding.ma,https://facturation.elbouazzatiholding.ma
# Next.js backend api (for cookies)
NEXT_PUBLIC_BACKEND_DOMAIN=facturation.elbouazzatiholding.ma
NEXT_PUBLIC_BACKEND_API="${HTTP}${NEXT_PUBLIC_BACKEND_DOMAIN}/api"
NEXT_PUBLIC_API_ROOT_URL=facturation-api.elbouazzatiholding.ma
NEXT_PUBLIC_API_ROOT_PORT=443
NEXT_PUBLIC_API_URL="${HTTP}${NEXT_PUBLIC_API_ROOT_URL}"
# Base urls
NEXT_PUBLIC_ROOT_API_URL="${HTTP}${NEXT_PUBLIC_API_ROOT_URL}:${NEXT_PUBLIC_API_ROOT_PORT}/api"
NEXT_PUBLIC_ROOT_WS_URL="${WS}${NEXT_PUBLIC_API_ROOT_URL}:${NEXT_PUBLIC_API_ROOT_PORT}/ws"
NEXT_PUBLIC_WS_MAINTENANCE_ROOT=/ws/maintenance/
# Auth
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=authSectetKey
NEXTAUTH_URL="${HTTP}${NEXT_PUBLIC_BACKEND_DOMAIN}"
NEXT_PUBLIC_DOMAIN_URL_PREFIX="${HTTP}${NEXT_PUBLIC_BACKEND_DOMAIN}"
# Account
NEXT_PUBLIC_ACCOUNT_ROOT=/account
NEXT_PUBLIC_ACCOUNT_REFRESH_TOKEN=/account/token_refresh/
NEXT_PUBLIC_ACCOUNT_LOGIN=/account/login/
NEXT_PUBLIC_ACCOUNT_LOGOUT=/account/logout/
NEXT_PUBLIC_ACCOUNT_CREATE_ACCOUNT=/account/create_account/
NEXT_PUBLIC_ACCOUNT_CHECK_EMAIL=/account/check_email/
NEXT_PUBLIC_ACCOUNT_PASSWORD_CHANGE=/account/password_change/
NEXT_PUBLIC_ACCOUNT_SEND_PASSWORD_RESET=/account/send_password_reset/
NEXT_PUBLIC_ACCOUNT_PASSWORD_RESET=/account/password_reset/
NEXT_PUBLIC_ACCOUNT_PROFIL=/account/profil/
NEXT_PUBLIC_ACCOUNT_GROUPS=/account/group/
NEXT_PUBLIC_USERS_ROOT=/account/users/
# Company
NEXT_PUBLIC_COMPANY_ROOT=/company
NEXT_PUBLIC_COMPANY_LIST=/company/
NEXT_PUBLIC_USER_COMPANIES_LIST=/company/by_user/
# Client
